                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select c.customer_id,
       o.book_id,
	   cast(c.order_date as date) as orderDate,
	   c.shipping_method_id,
	   o.line_id,
	   o.order_id,
	   o.price
from order_line o join cust_order c
on o.order_id = c.order_id</property>
